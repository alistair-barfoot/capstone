using UnityEngine;
using Unity.Robotics.ROSTCPConnector;
using RosMessageTypes.Sensor;
using System.Collections.Generic;

public class CameraImageSubscriberDebug : MonoBehaviour
{
    public string imageTopic = "/color/image_raw/compressed";
    public Renderer displayRenderer;

    private Texture2D cameraTexture;
    private int messageCount = 0;
    private readonly object imageLock = new object();
    private CompressedImageMsg latestImageMsg = null;
    private bool hasNewImage = false;

    void Start()
    {
        var ros = ROSConnection.GetOrCreateInstance();

        // FORCED QoS: Best Effort for high-bandwidth RGB data
        var bestEffort = new RosMessages.Unity.UnityRosSettings.RosTopicSettings { 
            Reliability = RosMessages.Unity.UnityRosSettings.RosTopicSettings.ReliabilitySetting.BestEffort 
        };

        ros.Subscribe<CompressedImageMsg>(imageTopic, UpdateCameraImage, bestEffort);

        if (displayRenderer == null) displayRenderer = GetComponent<Renderer>();
    }

    void UpdateCameraImage(CompressedImageMsg compressedMsg)
    {
        lock (imageLock)
        {
            latestImageMsg = compressedMsg;
            hasNewImage = true;
        }
    }

    void Update()
    {
        CompressedImageMsg imageToProcess = null;
        lock (imageLock)
        {
            if (hasNewImage)
            {
                imageToProcess = latestImageMsg;
                hasNewImage = false;
            }
        }

        if (imageToProcess != null) ProcessCompressedImage(imageToProcess);
    }

    void ProcessCompressedImage(CompressedImageMsg compressedMsg)
    {
        messageCount++;
        if (cameraTexture == null)
        {
            cameraTexture = new Texture2D(2, 2, TextureFormat.RGB24, false);
            cameraTexture.wrapMode = TextureWrapMode.Clamp;
        }

        if (ImageConversion.LoadImage(cameraTexture, compressedMsg.data))
        {
            displayRenderer.material.mainTexture = cameraTexture;
        }
    }
}
